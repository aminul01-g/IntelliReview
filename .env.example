# Application
DEBUG=True
APP_NAME=IntelliReview
APP_VERSION=1.0.0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
POSTGRES_USER=intellireview
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=intellireview_db

# MongoDB
MONGO_PASSWORD=change_this_password
MONGODB_URL=mongodb://admin:change_this_password@mongodb:27017

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# AI/ML APIs
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=bigcode/starcoder2-3b
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Security
SECRET_KEY=generate_a_secure_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

