# =============================================================================
# IntelliReview Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="IntelliReview"
APP_ENV=development
APP_URL=http://localhost:7860
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intellireview
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
PASSWORD_MIN_LENGTH=8

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# -----------------------------------------------------------------------------
# Google AI (Gemini)
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL_NAME=gemini-pro

# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL_NAME=Qwen/Qwen3-32B

# -----------------------------------------------------------------------------
# MongoDB (Optional - for logs)
# -----------------------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=intellireview_logs

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=60

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Code Analysis Limits
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_LINES=10000
MAX_FILE_SIZE_BYTES=1048576

# -----------------------------------------------------------------------------
# LLM Provider (Pattern Learning)
# Supported: huggingface | groq | google
# - "huggingface" uses HF Inference API (default, uses HUGGINGFACE_API_KEY)
# - "groq" uses Groq cloud (requires GROQ_API_KEY or HUGGINGFACE_API_KEY with Groq provider)
# - "google" uses Google Gemini (requires GOOGLE_API_KEY)
# All providers use chat_completion (conversational) task format.
# -----------------------------------------------------------------------------
LLM_PROVIDER=huggingface
HUGGINGFACE_PATTERN_MODEL=Qwen/Qwen3-32B
# GROQ_API_KEY=your-groq-api-key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
