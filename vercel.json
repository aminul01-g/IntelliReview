{
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/api/main.py" },
    { "src": "/health", "dest": "/api/main.py" },
    { "src": "/(.*)", "dest": "/dashboard/$1" }
  ]
}
