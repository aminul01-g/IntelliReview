{
  "name": "intellireview-vscode",
  "displayName": "IntelliReview Code Quality",
  "description": "AI-Powered Architectural Engine & Code Quality Analyzer",
  "version": "1.0.0",
  "publisher": "aminul-intellireview",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Machine Learning"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "intellireview.analyzeCurrentFile",
        "title": "IntelliReview: Analyze Current File"
      },
      {
        "command": "intellireview.clearDiagnostics",
        "title": "IntelliReview: Clear Analysis Results"
      }
    ],
    "configuration": {
      "title": "IntelliReview",
      "properties": {
        "intellireview.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000/api/v1",
          "description": "URL of the IntelliReview API Server"
        },
        "intellireview.apiToken": {
          "type": "string",
          "default": "",
          "description": "API Token (JWT) for IntelliReview authentication. Required for cloud analysis."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0"
  },
  "dependencies": {
    "axios": "^1.6.8"
  }
}
